        "executable": "gemini",
        "steps": [
          { "label": "install extension", "command": "gemini", "args": ["extensions", "install", "https://github.com/officialzeroxyz/zero-plugins", "--auto-update"] }
        ]
      }
    },
    {
      "id": "kiro",
      "name": "Kiro",
      "detect": { "exe": "kiro-cli", "dir": ".kiro" },
      "standalone": {
        "skills": [".kiro/skills", ".agents/skills"],
        "hooks": {
          "file": ".kiro/agents/zero.json",
          "format": "kiro-agent",
          "sessionStart": true,
          "merge": {
            "name": "zero",
            "description": "Zero — search, fetch, and pay for agent capabilities (zero.xyz)",
            "hooks": {
              "agentSpawn": [
                { "command": "bash \"${ZERO_HOOKS_DIR}/ensure-runner.sh\"", "timeout_ms": 120000 }
              ],
              "userPromptSubmit": [
                { "command": "bash \"${ZERO_HOOKS_DIR}/zero-context.sh\"", "timeout_ms": 5000 }
              ]
            }
          }
        }
      }
    },
