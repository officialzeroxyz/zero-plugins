{
  "schemaVersion": 1,
  "minCli": "1.9.0",
  "harnesses": [
    {
      "id": "claude-code",
      "name": "Claude Code",
      "detect": { "exe": "claude", "dir": ".claude" },
      "plugin": { "via": "claude-plugin", "marketplace": "officialzeroxyz/zero-plugins", "ref": "zero@zero-plugins" },
      "standalone": {
        "skills": [".claude/skills", ".agents/skills"],
        "hooks": { "file": ".claude/settings.json", "format": "claude-settings", "sessionStart": true }
      }
    },
    {
      "id": "codex",
      "name": "Codex",
      "detect": { "exe": "codex", "dir": ".codex" },
      "plugin": { "via": "codex-plugin", "marketplace": "officialzeroxyz/zero-plugins", "ref": "zero@zero-plugins" },
      "standalone": {
        "skills": [".agents/skills"],
        "hooks": { "file": ".codex/hooks.json", "format": "codex-hooks", "sessionStart": true }
      }
    },
    {
      "id": "droid",
      "name": "Droid",
      "detect": { "exe": "droid", "dir": ".factory" },
      "plugin": { "via": "factory-plugin", "marketplace": "https://github.com/officialzeroxyz/zero-plugins", "ref": "zero@zero-plugins", "scope": "user" }
    },
    {
      "id": "gemini-cli",
      "name": "Gemini CLI",
      "detect": { "exe": "gemini", "dir": ".gemini" },
      "plugin": { "via": "gemini-extension", "url": "https://github.com/officialzeroxyz/zero-plugins" }
    },
    {
      "id": "kiro",
      "name": "Kiro",
      "minCli": "1.10.0",
      "detect": { "exe": "kiro-cli", "dir": ".kiro" },
      "standalone": {
        "skills": [".kiro/skills", ".agents/skills"],
        "mcp": { "file": ".kiro/settings/mcp.json", "shape": "http-type-url" },
        "hooks": { "file": ".kiro/agents/zero.json", "format": "kiro-agent", "sessionStart": true }
      }
    }
  ]
}
