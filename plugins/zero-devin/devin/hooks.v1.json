{
  "SessionStart": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "bash \"$DEVIN_PROJECT_DIR/.devin/zero/hooks/ensure-runner.sh\"",
          "timeout": 120
        }
      ]
    }
  ],
  "UserPromptSubmit": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "bash \"$DEVIN_PROJECT_DIR/.devin/zero/hooks/zero-context.sh\"",
          "timeout": 5
        }
      ]
    }
  ],
  "PermissionRequest": [
    {
      "matcher": "^exec$",
      "hooks": [
        {
          "type": "command",
          "command": "bash \"$DEVIN_PROJECT_DIR/.devin/zero/hooks/auto-approve-zero.sh\"",
          "timeout": 5
        }
      ]
    }
  ]
}
